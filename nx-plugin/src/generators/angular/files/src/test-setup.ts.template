import { setupZoneTestEnv } from 'jest-preset-angular/setup-env/zone'

setupZoneTestEnv({
  errorOnUnknownElements: true,
  errorOnUnknownProperties: true
})

// Polyfill Canvas 2D context — jsdom doesn't implement one natively.
// Without this, Chart.js / PrimeNG <p-chart> throws "can't acquire context"
// and the error is forwarded through Zone.js ProxyZone to console.error.
const noop = () => mockContext2D as unknown as never;
const mockContext2D = {
  clearRect: noop,
  fillRect: noop,
  strokeRect: noop,
  fillText: noop,
  strokeText: noop,
  measureText: () => ({ width: 0, actualDescent: 0 } as TextMetrics),
  getImageData: () => ({ data: [] }),
  putImageData: noop,
  createImageData: () => ({ data: [] }),
  createLinearGradient: () => mockContext2D as unknown as CanvasGradient,
  setTransform: noop,
  getTransform: () => new DOMMatrix(),
  transform: noop,
  resetTransform: noop,
  scale: noop,
  rotate: noop,
  translate: noop,
  fill: noop,
  stroke: noop,
  beginPath: noop,
  moveTo: noop,
  lineTo: noop,
  arc: noop,
  closePath: noop,
  clip: noop,
  isPointInPath: () => false,
  isPointInStroke: () => false,
  save: noop,
  restore: noop,
  setLineDash: noop,
  getLineDash: () => [],
  setLineDashWidth: noop,
  arcTo: noop,
  bezierCurveTo: noop,
  quadraticCurveTo: noop,
  rect: noop,
  drawImage: noop,
  drawFocusIfNeeded: noop,
  reset: noop,
  resetTransform: noop,
} as CanvasRenderingContext2D;

HTMLCanvasElement.prototype.getContext = function (type: string, ..._args: unknown[]) {
  if (type === '2d') return mockContext2D;
  return mockContext2D;
};

// Polyfill Canvas 2D context — jsdom doesn't implement one, causing
// Chart.js / PrimeNG <p-chart> to throw "can't acquire context".
const mockContext = {} as unknown as CanvasRenderingContext2D;
const measureTextMock = () => ({ width: 0 });
HTMLCanvasElement.prototype.getContext = function() {
  return {
    ...mockContext,
    measureText,
    createLinearGradient: () => mockContext,
  } as unknown as CanvasRenderingContext2D;
} as never;
