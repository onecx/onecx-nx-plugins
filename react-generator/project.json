{
  "name": "react-generator",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "react-generator/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/react-generator",
        "main": "react-generator/src/index.ts",
        "tsConfig": "react-generator/tsconfig.lib.json",
        "assets": [
          "react-generator/*.md",
          {
            "input": "./react-generator/src",
            "glob": "**/!(*.ts)",
            "output": "./src"
          },
          {
            "input": "./react-generator/src",
            "glob": "**/*.d.ts",
            "output": "./src"
          },
          {
            "input": "./react-generator",
            "glob": "generators.json",
            "output": "."
          },
          {
            "input": "./react-generator",
            "glob": "executors.json",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "react-generator/jest.config.ts"
      }
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs react-generator {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "release": {
      "executor": "@onecx/release:update-build-publish",
      "options": {
        "libName": "react-generator"
      }
    }
  }
}
